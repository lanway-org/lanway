// Copy this file to oauth_secrets.dart (gitignored) and fill in your values.
//   - Google: Cloud Console → APIs & Services → Credentials → OAuth client ID
//             → Desktop app (gives the client id + GOCSPX secret).
//   - DigitalOcean: API → Applications (OAuth) → the client id (no secret; the
//             implicit grant is used).
const googleOAuthClientId = 'xxxxxxxx.apps.googleusercontent.com';
const googleOAuthClientSecret = 'GOCSPX-your-desktop-client-secret';
const digitalOceanClientId = 'your-digitalocean-oauth-client-id';
